# Säde v1 local configuration example
# Copy to .env only for local use. Do not commit .env.

SADE_OLLAMA_URL=http://127.0.0.1:11434/api/generate
SADE_OLLAMA_MODEL=gpt-oss:20b
SADE_TEMPERATURE=0.7
SADE_NUM_CTX=8192
SADE_MEMORY_CONTEXT_CHARS=6000
SADE_CHAT_CONTEXT_CHARS=4000
SADE_SEMANTIC_CONTEXT_CHARS=3500
SADE_SEMANTIC_SEARCH_RESULTS=5
SADE_RAG_CONTEXT_CHARS=4500
SADE_RAG_SEARCH_RESULTS=8
SADE_UI_LANGUAGE=en
SADE_AUTH_REQUIRED=true

# Web search provider selection:
# auto = Google if configured, then Brave if configured, otherwise DuckDuckGo Lite fallback.
# Allowed: auto, duckduckgo, duckduckgo_lite, brave, google.
SADE_WEB_SEARCH_PROVIDER=auto

# Optional Google Programmable Search / Custom Search JSON API.
# Requires a Google API key and Programmable Search Engine ID.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Optional Brave Search API fallback/provider.
BRAVE_SEARCH_API_KEY=
